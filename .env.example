HOST=0.0.0.0
PORT=3000
TIME_ZONE=Asia/Shanghai
STATS_FILE=./data/stats.json
REQUEST_TIMEOUT_MS=300000
TRUST_PROXY_HEADERS=true

# Optional: override the built-in direct redirect whitelist.
# MANUAL_REDIRECT_DOMAINS=aliyundrive.com,aliyundrive.net,cloudfront.net

# Optional: force specific domains to use a different upstream host when the
# request comes from a Japanese Cloudflare edge. Format: suffix=host[:port]
# DOMAIN_PROXY_RULES=blocked.example=proxy-us.example.com:8443

# Optional: override the Cloudflare edge colo list used with DOMAIN_PROXY_RULES.
# JP_COLOS=NRT,KIX,FUK,OKA
